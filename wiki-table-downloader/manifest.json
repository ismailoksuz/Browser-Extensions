{
    "manifest_version": 3,
    "name": "Wiki Table Downloader",
    "version": "1.0.0",
    "permissions": ["storage"],
    "action": {
      "default_popup": "popup.html"
    },
    "content_scripts": [
      {
        "matches": ["*://*.wikipedia.org/*"],
        "js": ["content.js"],
        "css": ["content.css"]
      }
    ]
  }